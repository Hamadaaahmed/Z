#!/bin/bash

SERVICE_NAME="zivpn"
BINARY_PATH="/usr/local/bin/zivpn-server"
SERVICE_FILE="/etc/systemd/system/${SERVICE_NAME}.service"
CONFIG_FILE="/etc/udp-zivpn/server.json"

show_header() {
  clear
  echo "=================================="
  echo "           ZIVPN MENU 1           "
  echo "=================================="
  echo "Service : ${SERVICE_NAME}"
  echo "Binary  : ${BINARY_PATH}"
  echo "Config  : ${CONFIG_FILE}"
  echo "=================================="
}

pause_screen() {
  echo
  read -r -p "Press Enter to continue..."
}

service_status() {
  systemctl status "${SERVICE_NAME}" --no-pager
}

start_service() {
  systemctl start "${SERVICE_NAME}"
  echo "Service started successfully."
}

stop_service() {
  systemctl stop "${SERVICE_NAME}"
  echo "Service stopped successfully."
}

restart_service() {
  systemctl restart "${SERVICE_NAME}"
  echo "Service restarted successfully."
}

enable_service() {
  systemctl enable "${SERVICE_NAME}"
  echo "Auto-start enabled successfully."
}

disable_service() {
  systemctl disable "${SERVICE_NAME}"
  echo "Auto-start disabled successfully."
}

view_logs() {
  journalctl -u "${SERVICE_NAME}" -n 50 --no-pager
}

view_config() {
  if [ -f "${CONFIG_FILE}" ]; then
    cat "${CONFIG_FILE}"
  else
    echo "Configuration file not found."
  fi
}

change_port() {
  if [ ! -f "${CONFIG_FILE}" ]; then
    echo "Configuration file not found: ${CONFIG_FILE}"
    return
  fi

  read -r -p "Enter the new port: " NEW_PORT

  if ! echo "${NEW_PORT}" | grep -Eq '^[0-9]+$'; then
    echo "Invalid port."
    return
  fi

  if [ "${NEW_PORT}" -lt 1 ] || [ "${NEW_PORT}" -gt 65535 ]; then
    echo "Port must be between 1 and 65535."
    return
  fi

  sed -i -E 's/"port"[[:space:]]*:[[:space:]]*[0-9]+/"port": '"${NEW_PORT}"'/' "${CONFIG_FILE}"
  systemctl restart "${SERVICE_NAME}"
  echo "Port changed to ${NEW_PORT} and service restarted."
}

menu_loop() {
  while true; do
    show_header
    echo "[1] Service Status"
    echo "[2] Start Service"
    echo "[3] Stop Service"
    echo "[4] Restart Service"
    echo "[5] Enable Auto-start"
    echo "[6] Disable Auto-start"
    echo "[7] View Recent Logs"
    echo "[8] View Configuration File"
    echo "[9] Change Port"
    echo "[0] Exit"
    echo "=================================="
    read -r -p "Select an option: " CHOICE

    case "${CHOICE}" in
      1) service_status; pause_screen ;;
      2) start_service; pause_screen ;;
      3) stop_service; pause_screen ;;
      4) restart_service; pause_screen ;;
      5) enable_service; pause_screen ;;
      6) disable_service; pause_screen ;;
      7) view_logs; pause_screen ;;
      8) view_config; pause_screen ;;
      9) change_port; pause_screen ;;
      0) exit 0 ;;
      *) echo "Invalid option."; pause_screen ;;
    esac
  done
}

menu_loop
