#!/bin/bash

SERVICE_NAME="zivpn"
BINARY_PATH="/usr/local/bin/zivpn-server"
SERVICE_FILE="/etc/systemd/system/${SERVICE_NAME}.service"
CONFIG_FILE="/etc/udp-zivpn/server.json"

show_header() {
  clear
  echo "=================================="
  echo "           ZIVPN MENU 1           "
  echo "=================================="
  echo "Service : ${SERVICE_NAME}"
  echo "Binary  : ${BINARY_PATH}"
  echo "Config  : ${CONFIG_FILE}"
  echo "=================================="
}

pause_screen() {
  echo
  read -r -p "Press Enter to continue..."
}

require_config() {
  if [ ! -f "${CONFIG_FILE}" ]; then
    echo "Configuration file not found: ${CONFIG_FILE}"
    return 1
  fi
  return 0
}

require_python() {
  if ! command -v python3 >/dev/null 2>&1; then
    echo "python3 is required for user management but is not installed."
    return 1
  fi
  return 0
}

service_status() {
  systemctl status "${SERVICE_NAME}" --no-pager
}

start_service() {
  systemctl start "${SERVICE_NAME}"
  echo "Service started successfully."
}

stop_service() {
  systemctl stop "${SERVICE_NAME}"
  echo "Service stopped successfully."
}

restart_service() {
  systemctl restart "${SERVICE_NAME}"
  echo "Service restarted successfully."
}

enable_service() {
  systemctl enable "${SERVICE_NAME}"
  echo "Auto-start enabled successfully."
}

disable_service() {
  systemctl disable "${SERVICE_NAME}"
  echo "Auto-start disabled successfully."
}

view_logs() {
  journalctl -u "${SERVICE_NAME}" -n 50 --no-pager
}

view_config() {
  if require_config; then
    cat "${CONFIG_FILE}"
  fi
}

change_port() {
  require_config || return
  require_python || return

  read -r -p "Enter the new port: " NEW_PORT

  if ! echo "${NEW_PORT}" | grep -Eq '^[0-9]+$'; then
    echo "Invalid port."
    return
  fi

  if [ "${NEW_PORT}" -lt 1 ] || [ "${NEW_PORT}" -gt 65535 ]; then
    echo "Port must be between 1 and 65535."
    return
  fi

  python3 - <<PY
import json
path = "${CONFIG_FILE}"
port = "${NEW_PORT}"
with open(path, "r", encoding="utf-8") as f:
    data = json.load(f)
data["listen"] = f":{port}"
with open(path, "w", encoding="utf-8") as f:
    json.dump(data, f, indent=2)
    f.write("\n")
PY

  systemctl restart "${SERVICE_NAME}"
  echo "Port changed to ${NEW_PORT} and service restarted."
}

list_users() {
  require_config || return
  require_python || return

  python3 - <<PY
import json
path = "${CONFIG_FILE}"
with open(path, "r", encoding="utf-8") as f:
    data = json.load(f)
users = data.get("auth", {}).get("userpass", {})
if not isinstance(users, dict) or not users:
    print("No users found.")
else:
    print("Configured users:")
    for name in sorted(users):
        print(f"- {name}")
PY
}

add_user() {
  require_config || return
  require_python || return

  read -r -p "Enter new username: " NEW_USER
  if [ -z "${NEW_USER}" ]; then
    echo "Username cannot be empty."
    return
  fi

  read -r -s -p "Enter password: " NEW_PASS
  echo
  if [ -z "${NEW_PASS}" ]; then
    echo "Password cannot be empty."
    return
  fi

  CONFIG_PATH="${CONFIG_FILE}" NEW_USER="${NEW_USER}" NEW_PASS="${NEW_PASS}" python3 - <<'PY'
import json
import os
import sys

path = os.environ["CONFIG_PATH"]
username = os.environ["NEW_USER"]
password = os.environ["NEW_PASS"]

with open(path, "r", encoding="utf-8") as f:
    data = json.load(f)

auth = data.setdefault("auth", {})
auth["mode"] = "userpass"
users = auth.setdefault("userpass", {})

if not isinstance(users, dict):
    print("Invalid userpass structure in config.")
    sys.exit(1)

if username in users:
    print("User already exists.")
    sys.exit(2)

users[username] = password

with open(path, "w", encoding="utf-8") as f:
    json.dump(data, f, indent=2)
    f.write("\n")

print("User added successfully.")
PY

  rc=$?
  if [ $rc -eq 0 ]; then
    systemctl restart "${SERVICE_NAME}"
    echo "Service restarted successfully."
  fi
}

delete_user() {
  require_config || return
  require_python || return

  read -r -p "Enter username to delete: " DEL_USER
  if [ -z "${DEL_USER}" ]; then
    echo "Username cannot be empty."
    return
  fi

  CONFIG_PATH="${CONFIG_FILE}" DEL_USER="${DEL_USER}" python3 - <<'PY'
import json
import os
import sys

path = os.environ["CONFIG_PATH"]
username = os.environ["DEL_USER"]

with open(path, "r", encoding="utf-8") as f:
    data = json.load(f)

users = data.get("auth", {}).get("userpass", {})
if not isinstance(users, dict):
    print("Invalid userpass structure in config.")
    sys.exit(1)

if username not in users:
    print("User not found.")
    sys.exit(2)

del users[username]

with open(path, "w", encoding="utf-8") as f:
    json.dump(data, f, indent=2)
    f.write("\n")

print("User deleted successfully.")
PY

  rc=$?
  if [ $rc -eq 0 ]; then
    systemctl restart "${SERVICE_NAME}"
    echo "Service restarted successfully."
  fi
}

change_user_password() {
  require_config || return
  require_python || return

  read -r -p "Enter username: " EDIT_USER
  if [ -z "${EDIT_USER}" ]; then
    echo "Username cannot be empty."
    return
  fi

  read -r -s -p "Enter new password: " EDIT_PASS
  echo
  if [ -z "${EDIT_PASS}" ]; then
    echo "Password cannot be empty."
    return
  fi

  CONFIG_PATH="${CONFIG_FILE}" EDIT_USER="${EDIT_USER}" EDIT_PASS="${EDIT_PASS}" python3 - <<'PY'
import json
import os
import sys

path = os.environ["CONFIG_PATH"]
username = os.environ["EDIT_USER"]
password = os.environ["EDIT_PASS"]

with open(path, "r", encoding="utf-8") as f:
    data = json.load(f)

users = data.get("auth", {}).get("userpass", {})
if not isinstance(users, dict):
    print("Invalid userpass structure in config.")
    sys.exit(1)

if username not in users:
    print("User not found.")
    sys.exit(2)

users[username] = password

with open(path, "w", encoding="utf-8") as f:
    json.dump(data, f, indent=2)
    f.write("\n")

print("Password updated successfully.")
PY

  rc=$?
  if [ $rc -eq 0 ]; then
    systemctl restart "${SERVICE_NAME}"
    echo "Service restarted successfully."
  fi
}

show_users_summary() {
  require_config || return
  require_python || return

  python3 - <<PY
import json
path = "${CONFIG_FILE}"
with open(path, "r", encoding="utf-8") as f:
    data = json.load(f)
users = data.get("auth", {}).get("userpass", {})
count = len(users) if isinstance(users, dict) else 0
listen = data.get("listen", "unknown")
print(f"Listen: {listen}")
print(f"Total users: {count}")
PY
}

menu_loop() {
  while true; do
    show_header
    show_users_summary
    echo "----------------------------------"
    echo "[1] Service Status"
    echo "[2] Start Service"
    echo "[3] Stop Service"
    echo "[4] Restart Service"
    echo "[5] Enable Auto-start"
    echo "[6] Disable Auto-start"
    echo "[7] View Recent Logs"
    echo "[8] View Configuration File"
    echo "[9] Change Port"
    echo "[10] List Users"
    echo "[11] Add User"
    echo "[12] Delete User"
    echo "[13] Change User Password"
    echo "[0] Exit"
    echo "=================================="
    read -r -p "Select an option: " CHOICE

    case "${CHOICE}" in
      1) service_status; pause_screen ;;
      2) start_service; pause_screen ;;
      3) stop_service; pause_screen ;;
      4) restart_service; pause_screen ;;
      5) enable_service; pause_screen ;;
      6) disable_service; pause_screen ;;
      7) view_logs; pause_screen ;;
      8) view_config; pause_screen ;;
      9) change_port; pause_screen ;;
      10) list_users; pause_screen ;;
      11) add_user; pause_screen ;;
      12) delete_user; pause_screen ;;
      13) change_user_password; pause_screen ;;
      0) exit 0 ;;
      *) echo "Invalid option."; pause_screen ;;
    esac
  done
}

menu_loop
